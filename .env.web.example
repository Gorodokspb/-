# Скопируйте этот файл в .env.web и подставьте реальные значения.

DEKORCRM_POSTGRES_DSN=postgresql://dekorcrm:CHANGE_ME@127.0.0.1:5432/dekorcrm
DEKORCRM_WEB_SECRET_KEY=CHANGE_ME_SECRET_KEY
DEKORCRM_WEB_USERNAME=aleksey
DEKORCRM_WEB_PASSWORD=CHANGE_ME_WEB_PASSWORD

# Локальный запуск:
DEKORCRM_WEB_HOST=127.0.0.1
DEKORCRM_WEB_PORT=8000

# Локальное тестовое хранилище:
DEKORCRM_STORAGE_ROOT=server_storage

# Для сервера можно использовать так:
# DEKORCRM_STORAGE_ROOT=/opt/dekorcrm/storage
# DEKORCRM_CONTRACTS_DIR=/opt/dekorcrm/storage/Договоры
# DEKORCRM_ESTIMATES_DIR=/opt/dekorcrm/storage/Сметы
# DEKORCRM_UPLOADS_DIR=/opt/dekorcrm/storage/uploads
